# ══════════════════════════════════════════════
#  মিরন ইলেকট্রনিক্স — Environment Variables
#  Copy this to .env.local for local development
#  Add these in Vercel Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════

# Supabase Project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (NOT the anon key — this bypasses RLS)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# ⚠️  Keep this SECRET — never expose it in client-side code
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
